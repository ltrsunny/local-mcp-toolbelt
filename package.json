{
  "name": "local-mcp-toolbelt-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo: local-mcp-toolbelt, a local-first MCP toolbelt for delegating inference tasks to in-process llama.cpp models.",
  "license": "Apache-2.0",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
