node_modules/
dist/
build/
.DS_Store
*.log
npm-debug.log*
.env
.env.local
.env.*.local
coverage/
.vscode/
.idea/
*.tsbuildinfo
.cache/
.claude/settings.local.json

# v0.3.0 Memory Bank — async job persistence at .memory/
# Users running bridge against this repo (or our own dogfooding) will
# create transient job files here; never commit them.
.memory/

# v0.5.0 eval harness — run outputs (one JSONL per matrix run).
# Reports under docs/notes/ are committed; raw runs are not.
packages/core/tests/eval/runs/

# Apple crash reports (.ips) — contain machine UUIDs + user paths.
# Keep locally in .claude/diagnostics/ for triage; never commit.
.claude/diagnostics/*.ips

# Raw curl/oMLX responses captured for ad-hoc diagnostics (e.g. thinking-mode
# probe outputs). Polished diagnostic docs in the same dir ARE committed.
.claude/diagnostics/*-raw.json

# Broken / partial agent outputs (when a background CLI task was stopped
# mid-run). Prompt files in the same dir ARE committed for replay.
.claude/brainstorm/eval-result.md
.claude/brainstorm/pa-mcp-result.md

# Per-session marker file for hook bypass during editing of any
# analysis path (brainstorm, scope-memos, notes, diagnostics,
# prior-art). The hook checks for this file's existence + mtime <60min
# and lifts analysis-path gating while present. Auto-expires.
# Per-machine state — don't ever commit it.
# Renamed 2026-05-22 from .scope-memo-edit-mode (broader scope now).
.claude/.bridge-edit-mode
.claude/.scope-memo-edit-mode

# Ephemeral working dir for diff captures, audit logs, etc. Anything
# worth keeping gets moved into .claude/brainstorm/ before commit.
tmp/

# Runtime lock file for ScheduleWakeup / loop infrastructure — per-session.
.claude/scheduled_tasks.lock

# Antigravity CLI per-project state (auto-created when running agy in cwd).
# Contains a symlink to ~/.gemini/config/projects/<uuid>.json — workspace
# scope is per-user, not for sharing.
.antigravitycli/
